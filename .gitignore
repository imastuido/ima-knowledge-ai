# .gitignore for ima-knowledge-ai

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Editor files
.vscode/
.idea/
*.sublime-*

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp

# Package files
node_modules/
__pycache__/
*.pyc
*.pyo

# Build artifacts
dist/
build/
*.egg-info/

# Local config
.env
.env.local
config.local.*

# ClawHub metadata (written by CLI)
.clawhub/
.clawdhub/
